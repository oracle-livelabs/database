SET LINESIZE 32767
COLUMN GEOM_WKT FORMAT A32767
COLUMN geometry_wkt FORMAT A32767

select ID, BoroCD, Shape_Leng, Shape_Area, GEOM_WKT, SDO_UTIL.TO_WKTGEOMETRY(GEOM_SDO) AS geometry_wkt from cds where BoroCD = 401;

select ID, ElectDist, ShapeArea, ShapeLen, GEOM_WKT, SDO_UTIL.TO_WKTGEOMETRY(GEOM_SDO) AS geometry_wkt from nyc_elect_districts where rownum < 21;

select r.ntaname, r.nta2020, r.cdta2020, r.cdtaname, r.ELECTDIST, r.relationship from (SELECT n.ntaname, n.nta2020, n.cdta2020, n.cdtaname, e.ELECTDIST, SDO_GEOM.RELATE(n.GEOM_SDO, 'determine', e.GEOM_SDO, 0.005) as relationship FROM NTAS n, ELECT_DISTRICTS e) r where r.relationship != 'DISJOINT' ;

select r.ntaname, r.nta2020, r.cdta2020, r.cdtaname, r.ELECTDIST, r.relationship from (SELECT n.ntaname, n.nta2020, n.cdta2020, n.cdtaname, e.ELECTDIST, SDO_GEOM.RELATE(n.GEOM_SDO, 'determine', e.GEOM_SDO, 0.005) as relationship FROM NTAS n, ELECT_DISTRICTS e) r;
  
		
		
DELETE elect_results WHERE UNIT_NAME IN ('Absentee / Military', 'Affidavit', 'Manually Counted Emergency', 'Special Presidential', 'Scattered');

SELECT r.EVENT, r.ADED, r.UNIT_NAME, r.TOTAL_TALLY, ne.NTANAME, demo.COMMUNITY_DISTRICT, demo.INDICATOR, demo.YR2010, demo.YR2019, demo.YR2022 FROM
	(SELECT EVENT, ADED, UNIT_NAME, TOTAL_TALLY FROM
		(SELECT EVENT, ADED, UNIT_NAME, SUM(TALLY) AS TOTAL_TALLY,
		RANK() OVER (PARTITION BY EVENT, ADED ORDER BY SUM(TALLY) DESC) AS rank_district
		FROM elect_results
		GROUP BY EVENT, ADED, UNIT_NAME)
		WHERE rank_district < 3) r, nta_elect ne, cd_demographics demo
		WHERE (r.ADED = ne.ELECTDIST) AND (ne.CDTA2020 = demo.COMMUNITY_DISTRICT);

SELECT EVENT, ADED, UNIT_NAME, TOTAL_TALLY, NTANAME, COMMUNITY_DISTRICT, INDICATOR, YR2010, YR2019, YR2022 FROM elect_result_demographics
		ORDER BY EVENT, ADED, INDICATOR, UNIT_NAME, TOTAL_TALLY;


