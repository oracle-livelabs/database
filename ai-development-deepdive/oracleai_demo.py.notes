DECLARE
	 profile_name VARCHAR2(255) := 'OCI_GENERATIVE_AI_PROFILE';
	 profile_found NUMBER := 0;
BEGIN
	SELECT COUNT(*) INTO profile_found FROM USER_CLOUD_AI_PROFILES WHERE profile_name = UPPER(profile_name);
	IF profile_found = 0  THEN
		 DBMS_CLOUD_AI.CREATE_PROFILE(
			 profile_name => 'OCI_GENERATIVE_AI_PROFILE',
			 attributes => JSON_OBJECT(
				 'provider' VALUE 'oci',
				 'region' VALUE 'us-chicago-1',
				 'oci_compartment_id' VALUE 'ocid1.compartment.oc1..aaaaaaaarxervkeaci5vxfghashg2vlqpvnopj2lxatx475ghp5jd46dxpfq',
				 'credential_name' VALUE 'OCI_CRED',
				 'model' VALUE 'meta.llama-3.2-90b-vision-instruct',
				 'object_list' VALUE JSON_ARRAY(
					 JSON_OBJECT('owner' VALUE 'VECTOR', 'name' VALUE 'Userinfo_vector'),
					 JSON_OBJECT('owner' VALUE 'VECTOR', 'name' VALUE 'Amex_stage_tab'),
					 JSON_OBJECT('owner' VALUE 'VECTOR', 'name' VALUE 'Userinfo_vector_ORCL_docs'),
					 JSON_OBJECT('owner' VALUE 'SH', 'name' VALUE 'customers'),
					 JSON_OBJECT('owner' VALUE 'SH', 'name' VALUE 'sales'),
					 JSON_OBJECT('owner' VALUE 'SH', 'name' VALUE 'products'),
					 JSON_OBJECT('owner' VALUE 'SH', 'name' VALUE 'countries')
				 )
			)
		);
	END IF;
	DBMS_CLOUD_AI.SET_PROFILE(profile_name => 'OCI_GENERATIVE_AI_PROFILE');
END;
