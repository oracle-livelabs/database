CREATE OR REPLACE FUNCTION RETRIEVAL_FUNC (p_query IN VARCHAR2,top_k IN NUMBER) RETURN SYS_REFCURSOR IS
    v_results SYS_REFCURSOR;
    v_sql     VARCHAR2(4000);
BEGIN
    v_sql := 'SELECT vector_distance(chunk_embedding, (vector_embedding(ALL_MPNET_BASE_V2 USING :1 AS data))) AS SCORE,
        doc_id AS DOCID, chunk_id AS CHUNKID, chunk_data AS BODY FROM UserInfo_ALL_MPNET_BASE_V2
        order by SCORE fetch approximate first :2 ROWS ONLY';

    OPEN v_results FOR 
		v_sql USING p_query, top_k;

    RETURN v_results;	
END;
/


set serveroutput on;
DECLARE
     p_var SYS_REFCURSOR;
     SCORE number;
     DOCID number;
     CHUNKID number;
     BODY VARCHAR2(4000 BYTE);
BEGIN
	 select RETRIEVAL_FUNC('In what business is Accertify',3) into p_var from dual;
     LOOP
         FETCH p_var INTO SCORE, DOCID, CHUNKID, BODY;
         EXIT WHEN p_var%NOTFOUND;
		 DBMS_OUTPUT.PUT_LINE('-----------------------------');
		 DBMS_OUTPUT.PUT_LINE('-----------------------------');
         DBMS_OUTPUT.PUT_LINE(SCORE || ', ' || DOCID || ', ' || CHUNKID);
         DBMS_OUTPUT.PUT_LINE(BODY);
    END LOOP;
    CLOSE p_var;
END;
/

