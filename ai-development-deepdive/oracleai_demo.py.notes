create or replace FUNCTION RETRIEVAL_FUNC (p_query IN VARCHAR2, top_k IN NUMBER) RETURN SYS_REFCURSOR IS
    v_results SYS_REFCURSOR;
    query_vec VECTOR;
BEGIN
    query_vec := dbms_vector.utl_to_embedding(
        p_query,
		json('{
			"provider":"database",
			"model":"ALL_MPNET_BASE_V2"
		}')
    );

    OPEN v_results FOR
		SELECT vector_distance(chunk_embedding, query_vec) AS SCORE,
		doc_id as DOCID, chunk_id as CHUNKID, chunk_data as BODY
		FROM UserInfo_ALL_MPNET_BASE_V2
		order by SCORE
		fetch approximate first top_k rows only;

    RETURN v_results;
END;
/


